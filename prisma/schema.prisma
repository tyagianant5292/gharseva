generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id               String           @id @default(cuid())
  // Email is OPTIONAL — many helpers don't have one. Mobile is the primary identity.
  email            String?          @unique
  passwordHash     String
  name             String
  mobile           String
  role             Role             @default(CUSTOMER)
  emailVerified    Boolean          @default(false)
  emailVerifyToken String?          @unique
  createdAt        DateTime         @default(now())
  provider         ProviderProfile?
  contactViews     ContactView[]    @relation("ViewerContacts")
  reviews          Review[]         @relation("AuthoredReviews")
  bookingRequests  BookingRequest[] @relation("CustomerRequests")
  instantBookings  InstantBooking[] @relation("CustomerInstantBookings")
}

model ProviderProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  services           String[] // e.g. ["MAID", "COOK"]
  country            String             @default("IN") // "IN" (India) | "AE" (UAE)
  city               String
  locality           String
  pincode            String
  lat                Float? // set when the helper pins their location
  lng                Float?
  gender             String?
  experienceYears    Int                @default(0)
  expectedSalary     Int? // monthly, INR
  instantAvailable   Boolean            @default(false) // offers daily / short-term bookings
  dailyRate          Int? // per-day rate for instant bookings (provider's currency)
  bio                String?
  photoUrl           String? // profile photo (data URL for MVP)
  photoThumbUrl      String? // tiny thumbnail for list cards
  ratingCount        Int                @default(0)
  ratingAvg          Float              @default(0)
  idDocUrl           String? // uploaded ID proof — front (data URL: image or PDF, admin-only)
  idDocBackUrl       String? // ID proof — back side (Aadhaar etc.)
  idDocType          String? // e.g. Aadhaar / PAN / Driving License
  verificationNote   String? // admin's note (e.g. rejection reason)
  available          Boolean            @default(true)
  verified           Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  contactViews       ContactView[]
  reviews            Review[]
  bookingRequests    BookingRequest[]
  instantBookings    InstantBooking[]

  @@index([city])
  @@index([pincode])
  @@index([verified])
}

// A date-range booking for daily / short-term ("instant") service.
// Payment is handled offline for now (cash to the helper on arrival).
model InstantBooking {
  id           String          @id @default(cuid())
  customerId   String
  customer     User            @relation("CustomerInstantBookings", fields: [customerId], references: [id], onDelete: Cascade)
  providerId   String
  provider     ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service      String
  startDate    DateTime
  endDate      DateTime
  days         Int
  ratePerDay   Int // snapshot of the provider's daily rate at booking time
  totalAmount  Int // days * ratePerDay
  message      String?
  status       RequestStatus   @default(PENDING)
  responseNote String? // provider's reason when declining
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([providerId])
  @@index([customerId])
}

model BookingRequest {
  id            String          @id @default(cuid())
  customerId    String
  customer      User            @relation("CustomerRequests", fields: [customerId], references: [id], onDelete: Cascade)
  providerId    String
  provider      ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service       String?
  message       String?
  preferredTime String?
  status        RequestStatus   @default(PENDING)
  responseNote  String? // provider's reason/note when declining (or accepting)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([customerId, providerId])
  @@index([providerId])
  @@index([customerId])
}

model Review {
  id         String          @id @default(cuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  authorId   String
  author     User            @relation("AuthoredReviews", fields: [authorId], references: [id], onDelete: Cascade)
  rating     Int // 1..5
  comment    String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([authorId, providerId])
  @@index([providerId])
}

// Records when a logged-in customer reveals a provider's contact (gating + leads).
model ContactView {
  id         String          @id @default(cuid())
  viewerId   String
  viewer     User            @relation("ViewerContacts", fields: [viewerId], references: [id], onDelete: Cascade)
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([viewerId, providerId])
}
