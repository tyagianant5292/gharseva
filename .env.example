# Neon Postgres — get these from your Neon project dashboard.
# DATABASE_URL uses the POOLED connection (…-pooler.…); DIRECT_URL is the direct one (for migrations).
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/gharseva?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/gharseva?sslmode=require"

# Secret for signing session JWTs (use a long random string).
AUTH_SECRET="change-me-to-a-long-random-string"

# Comma-separated emails that get admin access (verification panel at /admin).
ADMIN_EMAILS="you@example.com"

# Email verification via Brevo (https://brevo.com) — free, HTTP API (works on Vercel).
# Create an API key (SMTP & API → API Keys) and verify a sender email in Brevo.
# Leave BREVO_API_KEY empty to disable email sending (sign-up still works).
BREVO_API_KEY=""
MAIL_FROM="verified-sender@yourdomain.com"
MAIL_FROM_NAME="GharSeva"

# Public site URL (used in metadata).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
